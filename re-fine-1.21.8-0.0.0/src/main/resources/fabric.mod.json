{
	"schemaVersion": 1,
	"id": "re-fine",
	"version": "${version}",
	"name": "Re-Fine",
	"description": "A modern and up to date Vulkan based alternative to OptiFine, designed to have 99% OptiFine compatibility, apart form shaders.",
	"authors": [
		"NinesidedYT/Ninesideddevelopment"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/Ninesideddevelopment/Re-Fine/tree/main"
	},
	"license": "Apache 2.0",
	"icon": "assets/re-fine/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.ninesidedyt.re_fine.ReFine"
		],
		"client": [
			"com.ninesidedyt.re_fine.ReFineClient"
		]
	},
	"mixins": [
		"re-fine.mixins.json",
		"re-fine.client.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.16.14",
		"minecraft": "~1.21.8",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": {
		"another-mod": "*"
	}
}